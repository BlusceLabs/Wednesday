{
  "name": "wednesday",
  "version": "1.0.0-rc.7",
  "description": "A local-first personal agent built on Pi Agent Core, Pi AI, OpenTUI, durable Markdown memory, an authenticated dashboard, and a 106-tool registry.",
  "type": "module",
  "license": "MIT",
  "author": "BlusceLabs",
  "repository": {
    "type": "git",
    "url": "https://github.com/BlusceLabs/Wednesday.git"
  },
  "homepage": "https://github.com/BlusceLabs/Wednesday",
  "bugs": {
    "url": "https://github.com/BlusceLabs/Wednesday/issues"
  },
  "bin": {
    "wednesday": "./src/index.tsx"
  },
  "scripts": {
    "dev": "bun run src/index.tsx",
    "serve": "bun run src/serve.ts",
    "headless": "bun run src/headless.ts",
    "config": "bun run src/config-cli.ts",
    "migrate": "bun run src/migrate.ts",
    "setup:browser": "bun run src/setup-python.ts",
    "doctor": "bun run src/doctor.ts",
    "sandbox": "bun run src/sandbox-run.ts",
    "test": "bun test",
    "check": "tsc --noEmit",
    "start": "bun run src/index.tsx"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "0.80.10",
    "@earendil-works/pi-ai": "0.80.10",
    "@opentui/core": "0.3.1",
    "@opentui/react": "0.3.1",
    "react": "19.1.1"
  },
  "devDependencies": {
    "@types/bun": "1.2.18",
    "typescript": "5.8.3"
  }
}
